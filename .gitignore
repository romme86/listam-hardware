# Rust build artifacts (leaf-peer workspace + each crate)
target/

# ESP-IDF managed toolchain — regenerated by embuild (~3 GB)
.embuild/

# PlatformIO build output (esp32-s3-listam-bridge firmware)
.pio/

# Node dependencies (bridge driver)
node_modules/

# Device config with WiFi credentials and the hub control key.
# Provision from cfg.toml.example before building.
cfg.toml

# Generated menuconfig output (sdkconfig.defaults is the committed source)
sdkconfig
sdkconfig.old

# Local leaf/bridge mirror storage
/storage/
**/bridge/storage/

# macOS / editor / backups
.DS_Store
*.bak
